# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api

# Database (MySQL/PostgreSQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=lms_platform

# JWT (use long random strings in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=lms_token

# Payment (Razorpay or Stripe)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Zoho (CRM, Mail, Desk, Books, Analytics, Calendar)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CRM_ORG_ID=
ZOHO_CALENDAR_ID=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_API_BASE=https://www.zohoapis.com
ZOHO_BOOKS_ORG_ID=
ZOHO_BOOKS_CUSTOMER_ID=
ZOHO_CLIQ_WEBHOOK_URL=
ZOHO_MAIL_ACCOUNT_ID=
ZOHO_MAIL_FROM=
ZOHO_SIGN_TEMPLATE_ID=
ZOHO_SIGN_ACTION_ID=
ZOHO_WORKDRIVE_TEAM_ID=
ZOHO_MEETING_ZSOID=
ZOHO_MEETING_TIMEZONE=Asia/Kolkata
ZOHO_DESK_ORG_ID=
ZOHO_DESK_DEPARTMENT_ID=
ZOHO_ANALYTICS_WORKSPACE_ID=

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5500

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Recruiter access fee (stored in DB)
RECRUITER_ACCESS_AMOUNT=0
